{
  "name": "laravel-facade-resolver",
  "displayName": "Laravel Facade Resolver",
  "description": "Quickly resolve Laravel Facades to their bound classes on hover. Designed to speed up PHPStan Level 10 development.",
  "version": "1.0.0",
  "publisher": "pospisk",
  "repository": {
    "type": "git",
    "url": "https://github.com/pospisk/laravel-facade-resolver.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "laravel",
    "php",
    "phpstan",
    "facade",
    "larastan"
  ],
  "activationEvents": [
    "onLanguage:php"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Laravel Facade Resolver",
      "properties": {
        "laravelFacadeResolver.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the facade hover resolution."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  }
}
